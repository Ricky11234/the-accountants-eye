"impute\", SimpleImputer(strategy=\"most_frequent\")),\n","                        (\"onehot\", OneHotEncoder(handle_unknown=\"ignore\"))])\n","\n","preprocess = ColumnTransformer([(\"num\", numeric, num_cols),\n","                                (\"cat\", categorical, cat_cols)])\n","\n","print(\"train:\", X_train.shape, \"| test:\", X_test.shape)\n","print(\"train BAD rate:\", round(y_train.mean(), 3), \"| test BAD rate:\", round(y_test.mean(), 3))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"AsKy5Cu6Oada","executionInfo":{"status":"ok","timestamp":1783489749190,"user_tz":-330,"elapsed":1862,"user":{"displayName":"Abhinav Barman 4-Yr B.Tech.: Civil Engg., IIT(BHU)","userId":"02235557058045586589"}},"outputId":"969951d6-f87f-4f0f-8cfb-6c0a8a8e0890"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["train: (4768, 12) | test: (1192, 12)\n","train BAD rate: 0.199 | test BAD rate: 0.2\n"]}]},{"cell_type":"code","source":["from sklearn.linear_model import LogisticRegression\n","from sklearn.model_selection import StratifiedKFold, cross_val_score\n","import matplotlib.pyplot as plt, seaborn as sns\n","\n","# the <5%-null columns you targeted\n","low_null_cols = [\"VALUE\", \"CLNO\", \"REASON\", \"JOB\"]\n","cv = StratifiedKFold(5, shuffle=True, random_state=42)\n","model = LogisticRegression(max_iter=2000, class_weight=\"balanced\")\n","\n","def score(Xtr, ytr, label):\n","    pipe = Pipeline([(\"pre\", preprocess), (\"model\", model)])\n","    s = cross_val_score(pipe, Xtr, ytr, cv=cv, scoring=\"f1_macro\")\n","    print(f\"{label:32s} macro-F1 = {s.mean():.4f} ± {s.std():.4f}\")\n","    return s.mean()\n","\n","# (A) IMPUTE: keep all rows, let the pipeline impute\n","score(X_train, y_train, \"impute low-null cols (keep rows)\")\n","\n","# (B) DROP: remove train rows null in any low-null col, then run same pipeline\n","mask = X_train[low_null_cols].notna().all(axis=1)\n","X_drop, y_drop = X_train[mask], y_train[mask]\n